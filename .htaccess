RewriteEngine On

# Serve storage files directly from public/storage
RewriteCond %{REQUEST_URI} ^/storage/(.*)$
RewriteRule ^storage/(.*)$ public/storage/$1 [L]

# Serve public build assets directly
RewriteCond %{REQUEST_URI} ^/build/(.*)$
RewriteRule ^build/(.*)$ public/build/$1 [L]

# Route everything else through Laravel's public/index.php
RewriteRule ^(.*)$ public/$1 [L]
